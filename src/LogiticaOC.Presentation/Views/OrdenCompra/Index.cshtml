@model IEnumerable<DashboardItemDto>
@{
    ViewData["Title"] = "Órdenes de Compra";
    var filtros = ViewBag.Filtros as BusquedaVM;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h4 mb-0">Órdenes de Compra</h1>
    <button type="button" class="btn btn-primary btn-sm btn-nueva-oc">
        <i class="bi bi-plus-lg"></i> Nueva OC
    </button>
</div>

@{
    ViewData["Target"] = "#oc-table-container";
}
@await Html.PartialAsync("_FiltrosBusqueda", filtros)

<div id="oc-table-container">
    <partial name="_OrdenCompraTable" model="Model" />
</div>
