<!DOCTYPE html>
<html lang="es" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — LogiticaOC</title>
    <meta name="description" content="Sistema de gestión y seguimiento de Órdenes de Compra" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="sidebar">
        <div class="sidebar-brand">
            <i class="bi bi-truck-front-fill"></i>
            <span>LogiticaOC</span>
        </div>
        <ul class="sidebar-nav">
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")"
                   asp-controller="Dashboard" asp-action="Index">
                    <i class="bi bi-speedometer2"></i> Dashboard
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "OrdenCompra" ? "active" : "")"
                   asp-controller="OrdenCompra" asp-action="Index">
                    <i class="bi bi-file-earmark-text"></i> Órdenes de Compra
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Responsables" ? "active" : "")"
                   asp-controller="Responsables" asp-action="Index">
                    <i class="bi bi-people"></i> Responsables
                </a>
            </li>
            <li class="nav-divider"></li>
            <li class="nav-item">
                <form asp-controller="OrdenCompra" asp-action="GenerarHojaRuta" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="nav-link w-100 text-start border-0 bg-transparent">
                        <i class="bi bi-map"></i> Generar Hoja de Ruta
                    </button>
                </form>
            </li>
        </ul>

        <div class="sidebar-footer">
            <button id="themeToggle" class="theme-toggle-btn" title="Cambiar tema">
                <i class="bi bi-sun-fill" id="themeIcon"></i>
                <span id="themeLabel">Modo claro</span>
            </button>
        </div>
    </nav>

    <div class="main-content">
        <header class="topbar">
            <div class="topbar-title">@ViewData["Title"]</div>
            <div class="topbar-right">
                <div class="topbar-datetime">
                    <i class="bi bi-calendar3"></i>
                    <span id="liveDatetime"></span>
                </div>
            </div>
        </header>

        <main class="content-area">
            @if (TempData["Exito"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>@TempData["Exito"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </main>
    </div>

    <!-- Modal para Nueva OC -->
    <div class="modal fade" id="nuevaOcModal" tabindex="-1" aria-labelledby="nuevaOcModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-xl">
            <div class="modal-content border-0 shadow">
                <div class="modal-header border-bottom border-secondary d-flex align-items-center justify-content-between" style="background-color: var(--bg-sidebar); color: var(--text); padding-right: 1.5rem;">
                    <h5 class="modal-title" id="nuevaOcModalLabel">
                        <i class="bi bi-file-earmark-plus-fill me-2 text-accent"></i>Registrar Nueva Orden de Compra
                    </h5>
                    <div class="d-flex align-items-center gap-3">
                        <!-- Minimizar Borrador -->
                        <button type="button" class="btn p-1" id="btnMinimizarModal" title="Minimizar borrador" style="background: transparent; border: none; color: rgba(255, 255, 255, 0.75); transition: all 0.2s;" onmouseover="this.style.color='#f97316'; this.style.transform='scale(1.15)';" onmouseout="this.style.color='rgba(255, 255, 255, 0.75)'; this.style.transform='scale(1)';">
                            <i class="bi bi-dash-lg fs-4 fw-bold"></i>
                        </button>
                        <!-- Cerrar Modal -->
                        <button type="button" class="btn p-1" data-bs-dismiss="modal" aria-label="Cerrar" style="background: transparent; border: none; color: rgba(255, 255, 255, 0.75); transition: all 0.2s;" onmouseover="this.style.color='#ef4444'; this.style.transform='scale(1.15)';" onmouseout="this.style.color='rgba(255, 255, 255, 0.75)'; this.style.transform='scale(1)';">
                            <i class="bi bi-x-lg fs-4 fw-bold"></i>
                        </button>
                    </div>
                </div>
                <div class="modal-body" id="nuevaOcModalBody" style="background-color: var(--bg-card); color: var(--text);">
                    <!-- Carga AJAX -->
                    <div class="text-center py-5">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Cargando...</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Dock de Borrador Minimizado -->
    <div id="modalDraftDock" class="modal-draft-dock border border-secondary shadow-lg" style="display:none;">
        <div class="d-flex align-items-center justify-content-between px-3 py-2" style="cursor:pointer;" id="dockHeader">
            <span class="text-white small fw-bold text-truncate me-2" style="max-width: 180px;">
                <i class="bi bi-file-earmark-text text-accent me-2"></i>Borrador: <span id="draftOcNumber">Nueva OC</span>
            </span>
            <div class="d-flex gap-2">
                <button id="btnRestoreDraft" class="btn btn-sm btn-link text-white p-0" title="Restaurar formulario"><i class="bi bi-window-fullscreen fs-6"></i></button>
                <button id="btnDiscardDraft" class="btn btn-sm btn-link text-danger p-0" title="Descartar borrador"><i class="bi bi-trash fs-6"></i></button>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://code.jquery.com/ui/1.13.2/jquery-ui.min.js"></script>
    <link rel="stylesheet" href="https://code.jquery.com/ui/1.13.2/themes/base/jquery-ui.css" />
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

